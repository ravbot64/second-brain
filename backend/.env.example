# ==============================================================================
# SECOND BRAIN - Environment Configuration
# ==============================================================================

# DATABASE CONFIGURATION
# ─────────────────────
# For LOCAL development (SQLite):
#   DB_URL=sqlite:///./second_brain.db
# For PRODUCTION (Supabase PostgreSQL):
#   DB_URL=postgresql://user:password@db.supabase.co:5432/postgres
DB_URL=postgresql://user:password@db.supabase.co:5432/postgres

# QDRANT VECTOR DB CONFIGURATION
# ──────────────────────────────
# For LOCAL development (file-based):
#   QDRANT_URL=
#   QDRANT_PATH=./qdrant_data
# For PRODUCTION (Qdrant Cloud):
#   QDRANT_URL=https://xxx-xxx.qdrant.io:6333
#   QDRANT_API_KEY=your_api_key
QDRANT_URL=https://xxx-xxx.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_api_key
QDRANT_PATH=./qdrant_data

# CORS CONFIGURATION
# ──────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://yourdomain.com
# Set to false if you do not need cookies/auth headers across origins
CORS_ALLOW_CREDENTIALS=true

# LLM CONFIGURATION
# ─────────────────
LLM_MODEL=gemini-2.5-flash

# AUTH CONFIGURATION
# ──────────────────
# Set a long random secret (>=32 chars) in production.
JWT_SECRET=replace_with_a_long_random_secret_min_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# RETRIEVAL SETTINGS
# ──────────────────
RETRIEVAL_TOP_K=5
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# FILE SIZE LIMITS
# ────────────────
# 50MB in bytes
MAX_FILE_SIZE=52428800
# 10MB in bytes
MAX_CONTENT_LENGTH=10485760
# Character limit for queries
MAX_QUERY_LENGTH=5000
